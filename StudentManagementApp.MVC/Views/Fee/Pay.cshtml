@model StudentManagement.Core.Models.Fee

<div class="container mt-4">
    <div class="card shadow border-primary">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Add Payment Process</h4>
        </div>
        <div class="card-body">

            <div class="alert alert-info py-3 mb-4">
                <div class="row">
                    <div class="col-md-4">
                        <strong>Student:</strong> @Model.Student?.FirstName @Model.Student?.LastName (@Model.Student?.RollNumber)
                    </div>
                    <div class="col-md-4">
                        <strong>Course:</strong> @Model.Course?.Name
                    </div>
                    <div class="col-md-4">
                        <strong>Remaining Balance:</strong> <span class="text-danger fw-bold">@((Model.AmountDue - Model.AmountPaid).ToString("C"))</span>
                    </div>
                </div>
            </div>

            <form asp-action="Pay" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="StudentId" />
                <input type="hidden" asp-for="CourseId" />

                <div class="mb-3">
                    <label class="form-label">Payment Amount</label>
                    <input type="number" name="amount" min="0.01" step="0.01" max="@(Model.AmountDue - Model.AmountPaid)" class="form-control" required placeholder="Enter paid amount..." />
                </div>

                <div class="mb-3">
                    <label class="form-label">Transaction Remarks</label>
                    <textarea name="remarks" class="form-control" rows="3" placeholder="Reference ID, Bank deposit, etc."></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success"><i class="fas fa-check"></i> Submit Payment</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>