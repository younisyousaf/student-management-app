@model StudentManagement.Core.Models.Fee

@{
    ViewData["Title"] = "Fee Ledger Details";
}

<div class="container mt-5">
    <div class="card border-info shadow-sm">
        <!-- Header -->
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i> Invoice & Payment Details</h4>
            <a asp-action="Index" class="btn btn-sm btn-light text-dark fw-bold">
                <i class="fas fa-arrow-left me-1"></i> Back to Ledgers
            </a>
        </div>

        <div class="card-body p-4">
            <!-- Top Section: Student and Course Info -->
            <div class="row mb-4">
                <div class="col-md-6 border-end">
                    <h5 class="text-secondary fw-bold mb-3"><i class="fas fa-user-graduate me-2"></i>Student Information</h5>
                    <p class="mb-2"><strong>Roll Number:</strong> <span class="badge bg-secondary font-monospace">@Model.Student?.RollNumber</span></p>
                    <p class="mb-2"><strong>Name:</strong> @Model.Student?.FirstName @Model.Student?.LastName</p>
                    <p class="mb-0"><strong>Email:</strong> <span class="text-muted">@Model.Student?.Email</span></p>
                </div>
                <div class="col-md-6 ps-md-4">
                    <h5 class="text-secondary fw-bold mb-3"><i class="fas fa-book me-2"></i>Course Details</h5>
                    <p class="mb-2"><strong>Course Name:</strong> @Model.Course?.Name</p>
                    <p class="mb-2"><strong>Course Code:</strong> <span class="font-monospace">@Model.Course?.Code</span></p>
                    <p class="mb-0"><strong>Total Course Fee:</strong> <span class="fw-bold">@Model.AmountDue.ToString("C")</span></p>
                </div>
            </div>

            <hr />

            <!-- Middle Section: Financial Summary Cards -->
            <div class="row my-4 g-3">
                <div class="col-md-4">
                    <div class="p-3 bg-light border-start border-3 border-dark rounded text-center">
                        <span class="text-uppercase text-muted small fw-bold">Total Course Fee</span>
                        <h3 class="text-dark mt-1 mb-0">@Model.AmountDue.ToString("C")</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 bg-light border-start border-3 border-success rounded text-center">
                        <span class="text-uppercase text-muted small fw-bold">Total Paid</span>
                        <h3 class="text-success mt-1 mb-0">@Model.AmountPaid.ToString("C")</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 bg-light border-start border-3 border-danger rounded text-center">
                        <span class="text-uppercase text-muted small fw-bold">Remaining Balance</span>
                        <h3 class="text-danger mt-1 mb-0">@((Model.AmountDue - Model.AmountPaid).ToString("C"))</h3>
                    </div>
                </div>
            </div>

            <div class="row">
                <!-- Status & Actions -->
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-light bg-light">
                        <div class="card-body d-flex flex-column justify-content-between text-center">
                            <div>
                                <span class="text-uppercase text-muted small fw-bold d-block mb-2">Current Status</span>
                                @if (Model.Status == StudentManagement.Core.Enums.PaymentStatus.Paid)
                                {
                                    <span class="badge bg-success fs-5 px-4 py-2">Fully Paid</span>
                                }
                                else if (Model.Status == StudentManagement.Core.Enums.PaymentStatus.Partial)
                                {
                                    <span class="badge bg-warning text-dark fs-5 px-4 py-2">Partially Paid</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-5 px-4 py-2">Unpaid</span>
                                }
                            </div>

                            <div class="mt-4">
                                @if (Model.Status != StudentManagement.Core.Enums.PaymentStatus.Paid)
                                {
                                    <a asp-action="Pay" asp-route-id="@Model.Id" class="btn btn-primary w-100">
                                        <i class="fas fa-coins me-1"></i> Make a Payment
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100" disabled>
                                        <i class="fas fa-check-circle me-1"></i> No Action Needed
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment History Log -->
                <div class="col-md-8 mb-4">
                    <h5 class="text-secondary fw-bold mb-3"><i class="fas fa-history me-2"></i>Fee Payment History Log</h5>
                    <div class="bg-dark text-light p-3 rounded font-monospace shadow-inner" style="white-space: pre-line; min-height: 120px; font-size: 0.9rem;">
                        @(string.IsNullOrWhiteSpace(Model.Remarks) ? "No physical payments logged yet for this invoice entry." : Model.Remarks)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>