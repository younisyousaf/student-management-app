@model IEnumerable<StudentManagementApp.MVC.ViewModels.FeeIndexViewModel>

@{
    ViewData["Title"] = "Fee Ledgers";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-exclamation-triangle me-1"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0"><i class="fas fa-wallet me-2"></i>Fee Ledgers</h4>
            <a asp-action="Create" class="btn btn-warning text-dark fw-bold btn-sm">
                <i class="fas fa-plus me-1"></i> Create Fee Entry
            </a>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Student Name</th>
                            <th>Amount Due</th>
                            <th>Amount Paid</th>
                            <th>Payment Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-folder-open fa-2x mb-2 d-block"></i> No fee ledgers found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.StudentName</strong></td>
                                    <td>@item.AmountDue.ToString("C")</td>
                                    <td class="text-success fw-bold">@item.AmountPaid.ToString("C")</td>
                                    <td>
                                        @(item.PaymentDate == DateTime.MinValue ? "No Payments Logged" : item.PaymentDate.ToString("yyyy-MM-dd"))
                                    </td>
                                    <td>
                                        @if (item.AmountPaid <= 0)
                                        {
                                            <span class="badge bg-danger">Unpaid</span>
                                        }
                                        else if (item.AmountPaid >= item.AmountDue)
                                        {
                                            <span class="badge bg-success">Fully Paid</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Partial</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (item.AmountPaid < item.AmountDue)
                                        {
                                            <a asp-action="Pay" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-2">
                                                <i class="fas fa-coins me-1"></i> Pay
                                            </a>
                                        }
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">
                                            <i class="fas fa-info-circle me-1"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>