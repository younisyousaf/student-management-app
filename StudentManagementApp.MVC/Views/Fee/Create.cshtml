@model StudentManagementApp.MVC.ViewModels.CreateFeeViewModel

@{
    ViewData["Title"] = "Process Payment";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i> Process Student Payment</h4>
                </div>
                <div class="card-body p-4">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form asp-action="Create" method="post">
                        <!-- Searchable Student Select via Select2 AJAX -->
                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label fw-bold">Select Student</label>
                            <select asp-for="StudentId" id="studentFeeSelect" class="form-control select2-ajax" required>
                                <option value="">Search for a student (Roll No or Name)...</option>
                            </select>
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <!-- Searchable Course Select via Select2 AJAX -->
                        <div class="mb-3">
                            <label asp-for="CourseId" class="form-label fw-bold">Select Course</label>
                            <select asp-for="CourseId" id="courseFeeSelect" class="form-control select2-ajax" required>
                                <option value="">Search for a course (Code or Name)...</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Amount" class="form-label fw-bold"></label>
                                <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                <span asp-validation-for="Amount" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PaymentDate" class="form-label fw-bold"></label>
                                <input asp-for="PaymentDate" type="date" class="form-control" />
                                <span asp-validation-for="PaymentDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Remarks" class="form-label fw-bold"></label>
                            <textarea asp-for="Remarks" class="form-control" rows="2" placeholder="e.g. Paid via Bank Transfer, Receipt #10243"></textarea>
                            <span asp-validation-for="Remarks" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Back to Ledger
                            </a>
                            <button type="submit" class="btn btn-danger px-4">Submit Payment</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            // Student AJAX Auto-complete
            $('#studentFeeSelect').select2({
                placeholder: 'Type Roll No or Name...',
                minimumInputLength: 0,
                width: '100%',
                ajax: {
                    url: '/Student/SearchStudents',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return {
                            searchTerm: params.term
                        };
                    },
                    processResults: function(data) {
                        return {
                            results: data
                        };
                    },
                    cache: true
                }
            });

            // Course AJAX Auto-complete
            $('#courseFeeSelect').select2({
                placeholder: 'Type Code or Name...',
                minimumInputLength: 0,
                width: '100%',
                ajax: {
                    url: '/Course/SearchCourses',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return {
                            searchTerm: params.term
                        };
                    },
                    processResults: function(data) {
                        return {
                            results: data
                        };
                    },
                    cache: true
                }
            });
        });
    </script>
}