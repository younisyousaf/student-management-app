@model StudentManagementApp.MVC.Models.PaginatedList<StudentManagementApp.MVC.Models.EnrollmentIndexViewModel>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Enrollment List</h4>
        <a asp-action="Create" class="btn btn-light btn-sm"><i class="fas fa-plus"></i> New Enrollment</a>
    </div>
    <div class="card-body">
        <!-- Search bar -->
        <form method="get" asp-action="Index" class="row g-3 mb-4">
            <div class="col-md-9">
                <input type="text" name="search" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by Student Roll No, Name or Course..." />
            </div>
            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-outline-primary">Search</button>
            </div>
        </form>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Roll Number</th>
                    <th>Student Name</th>
                    <th>Course Name</th>
                    <th>Course Fee</th>
                    <th>Amount Paid</th>
                    <th>Amount Due</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.RollNumber</strong></td>
                        <td>@item.StudentName</td>
                        <td>@item.CourseName</td>
                        <td>@item.CourseFee.ToString("C")</td>
                        <td class="text-success">@item.AmountPaid.ToString("C")</td>
                        <td class="text-danger font-monospace">@item.AmountDue.ToString("C")</td>
                        <td>
                            <span class="badge @(item.Status == "Active" ? "bg-success" : item.Status == "Completed" ? "bg-dark text-white" : "bg-danger") px-2 py-2 fs-6">
                                @item.Status
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-eye"></i> Manage
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Pagination Controls -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span>Page @Model.PageIndex of @Model.TotalPages (Total Records: @Model.TotalCount)</span>
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-search="@ViewData["CurrentFilter"]">Previous</a>
                    </li>
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-search="@ViewData["CurrentFilter"]">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>