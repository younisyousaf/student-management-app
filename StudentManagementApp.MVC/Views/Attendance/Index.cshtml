@model IEnumerable<StudentManagementApp.MVC.ViewModels.AttendanceRowViewModel>
@{
    ViewData["Title"] = "Attendance";
}

<div class="container mt-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (ViewData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-1">@ViewData["ErrorMessage"]</i>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0"><i class="fas fa-calendar-check me-2"></i>Attendance</h4>
            <a asp-action="Mark" class="btn btn-sm btn-light text-primary fw-bold">
                <i class="fas fa-plus me-1"></i> Mark Attendance
            </a>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 mb-4">
                <div class="col-md-9">
                    <input type="text" name="rollNumber" value="@ViewData["CurrentRoll"]" class="form-control" placeholder="Enter Student Roll Number..." />
                </div>
                <div class="col-md-3 d-grid">
                    <button type="submit" class="btn btn-primary">View History</button>
                </div>
            </form>

            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr><th>Course</th><th>Date</th><th>Status</th><th>Remarks</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="fas fa-calendar-times fa-2x mb-2 d-block"></i> No attendance records yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in Model)
                        {
                            <tr>
                                <td>@row.CourseName</td>
                                <td>@row.Date.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span class="badge @(
                                          row.Status == StudentManagement.Core.Enums.AttendanceStatus.Present ? "bg-success" :
                                          row.Status == StudentManagement.Core.Enums.AttendanceStatus.Absent ? "bg-danger" :
                                          "bg-warning text-dark")">
                                        @row.Status
                                    </span>
                                </td>
                                <td>@(row.Remarks ?? "-")</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>