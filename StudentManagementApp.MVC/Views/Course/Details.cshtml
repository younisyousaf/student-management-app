@model StudentManagement.Core.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="fas fa-book-open me-2"></i>Course Information</h4>
                    <span class="badge bg-light text-success font-monospace px-3 py-2 fs-6">Code: @Model.Code</span>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h3 class="mt-3 mb-1">@Model.Name</h3>
                        <p class="text-muted">Academic Program Registry</p>
                    </div>

                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr>
                                <th class="table-light w-33"><i class="fas fa-fingerprint me-2 text-muted"></i> Course Key ID</th>
                                <td class="font-monospace">@Model.Id</td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-clock me-2 text-muted"></i> Academic Duration</th>
                                <td>@Model.DurationMonths Months</td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-dollar-sign me-2 text-muted"></i> Base Tuition Cost</th>
                                <td class="fw-bold text-success">@Model.FeeAmount.ToString("C")</td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-align-left me-2 text-muted"></i> Curriculum Description</th>
                                <td class="text-wrap">
                                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided for this academic program yet." : Model.Description)
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Catalog
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success px-4">
                            <i class="fas fa-edit me-1"></i> Edit parameters
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>