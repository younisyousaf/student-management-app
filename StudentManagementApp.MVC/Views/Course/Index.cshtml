@model StudentManagementApp.MVC.Models.PaginatedList<StudentManagement.Core.Models.Course>

@{
    ViewData["Title"] = "Course Catalog";
}

<div class="container mt-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0"><i class="fas fa-book me-2"></i>Course Catalog</h4>
            <a asp-action="Create" class="btn btn-sm btn-light text-success fw-bold">
                <i class="fas fa-plus me-1"></i> Add New Course
            </a>
        </div>
        <div class="card-body">
            <!-- Search Filter Bar -->
            <form method="get" asp-action="Index" class="row g-3 mb-4">
                <div class="col-md-9">
                    <input type="text" name="search" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by Course Code or Name..." />
                </div>
                <div class="col-md-3 d-grid">
                    <button type="submit" class="btn btn-success">Search</button>
                </div>
            </form>

            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Course Code</th>
                        <th>Course Name</th>
                        <th>Duration (Months)</th>
                        <th>Base Rate Fee</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="fas fa-folder-open fa-2x mb-2 d-block"></i> No courses registered yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var course in Model)
                        {
                            <tr>
                                <td><span class="badge bg-success font-monospace px-2 py-1">@course.Code</span></td>
                                <td><strong>@course.Name</strong></td>
                                <td>@course.DurationMonths Months</td>
                                <td>@course.FeeAmount.ToString("C")</td>
                                <td class="text-end">
                                        <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-success" title="Edit">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-secondary" title="Details">
                                            <i class="fas fa-eye"></i> Details
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="fas fa-trash-alt"></i> Delete
                                        </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <!-- Pagination Controls -->
            @if (Model != null && Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="text-muted">Page @Model.PageIndex of @Model.TotalPages (Total Records: @Model.TotalCount)</span>
                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link text-success" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-search="@ViewData["CurrentFilter"]">Previous</a>
                            </li>
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link text-success" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-search="@ViewData["CurrentFilter"]">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>