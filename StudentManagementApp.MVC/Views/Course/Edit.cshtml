@model StudentManagementApp.MVC.ViewModels.EditCourseViewModel

@{
    ViewData["Title"] = "Edit Course";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Course Parameters</h4>
                </div>
                <div class="card-body p-4">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CourseCode" />

                        <div class="row">
                            <!-- Course Code is preserved and display-only -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="CourseCode" class="form-label fw-bold"></label>
                                <input class="form-control bg-light text-muted font-monospace" value="@Model.CourseCode" readonly />
                                <span class="text-muted small">Course codes represent strict structural keys.</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="CourseName" class="form-label fw-bold"></label>
                                <input asp-for="CourseName" class="form-control" />
                                <span asp-validation-for="CourseName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Provide details about curriculum, target student demographics..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DurationMonths" class="form-label fw-bold"></label>
                                <input asp-for="DurationMonths" type="number" class="form-control" />
                                <span asp-validation-for="DurationMonths" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="FeeAmount" class="form-label fw-bold"></label>
                                <input asp-for="FeeAmount" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="FeeAmount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success px-4">Update Course</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}