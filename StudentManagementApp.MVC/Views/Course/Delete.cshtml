@model StudentManagement.Core.Models.Course

@{
    ViewData["Title"] = "Delete Course Catalog Entry";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger shadow-sm border-2" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i> <strong>Deletion Rejected:</strong> @ViewBag.ErrorMessage
                </div>
            }

            <div class="card border-danger shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-trash-alt me-2"></i> Danger Zone: Delete Course</h4>
                </div>
                <div class="card-body p-4 text-center">
                    <i class="fas fa-exclamation-triangle fa-4x text-danger mb-3"></i>
                    <h3 class="card-title text-danger fw-bold">Remove Course Permanently?</h3>
                    <p class="card-text mb-4 text-muted fs-5">
                        You are attempting to delete course <strong>@Model.Name</strong> (<span class="font-monospace text-dark">@Model.Code</span>) from the academic catalog.
                    </p>

                    <div class="row justify-content-center mb-4">
                        <div class="col-md-8">
                            <ul class="list-group list-group-flush border text-start rounded">
                                <li class="list-group-item"><strong>Course Code:</strong> @Model.Code</li>
                                <li class="list-group-item"><strong>Name:</strong> @Model.Name</li>
                                <li class="list-group-item"><strong>Tuition Rate:</strong> @Model.FeeAmount.ToString("C")</li>
                            </ul>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-secondary px-4">
                                Cancel, Keep Course
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                Confirm Permanent Deletion
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>