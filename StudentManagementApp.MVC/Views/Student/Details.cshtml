@model StudentManagement.Core.Models.Student

@{
    ViewData["Title"] = "Student Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <!-- Header -->
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="fas fa-id-card me-2"></i> Student Profile File</h4>
                    <span class="badge bg-warning text-dark font-monospace px-3 py-2 fs-6">Roll #: @Model.RollNumber</span>
                </div>

                <div class="card-body p-4">
                    <!-- Profile Avatar Header -->
                    <div class="row mb-4">
                        <div class="col text-center">
                            <h3 class="mt-3 mb-1">@Model.FirstName @Model.LastName</h3>
                            <p class="text-muted mb-0">Registered Student Account</p>
                        </div>
                    </div>

                    <!-- Details Grid -->
                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr>
                                <th class="table-light w-33"><i class="fas fa-fingerprint me-2 text-muted"></i> Database ID Key</th>
                                <td class="font-monospace">@Model.Id</td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-envelope me-2 text-muted"></i> Contact Email</th>
                                <td><a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a></td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-calendar-alt me-2 text-muted"></i> Birth Date</th>
                                <td>@Model.DateOfBirth.ToString("yyyy MMMM dd")</td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-phone me-2 text-muted"></i> Phone Number</th>
                                <td>@(string.IsNullOrWhiteSpace(Model.Phone) ? "Not Provided" : Model.Phone)</td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-map-marker-alt me-2 text-muted"></i> Address</th>
                                <td>@(string.IsNullOrWhiteSpace(Model.Address) ? "Not Provided" : Model.Address)</td>
                            </tr>
                            <tr>
                                <th class="table-light"><i class="fas fa-university me-2 text-muted"></i> Admission Date</th>
                                <td>@Model.AdmissionDate.ToString("yyyy-MM-dd HH:mm") (UTC)</td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- Action Footer -->
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Back to Directory
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4">
                            <i class="fas fa-edit me-1"></i> Edit Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>