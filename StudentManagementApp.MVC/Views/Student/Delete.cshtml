@model StudentManagement.Core.Models.Student

@{
    ViewData["Title"] = "Delete Student Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <!-- Displays validation or DB constraint errors if deletion is aborted -->
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger shadow-sm border-2" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i> <strong>Deletion Blocked:</strong> @ViewBag.ErrorMessage
                </div>
            }

            <div class="card border-danger shadow border-0">
                <!-- Header -->
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-user-slash me-2"></i> Danger Zone: Deletion Request</h4>
                </div>

                <div class="card-body p-4 text-center">
                    <i class="fas fa-exclamation-circle fa-4x text-danger mb-3"></i>
                    <h3 class="card-title text-danger fw-bold">Are you absolutely sure?</h3>
                    <p class="card-text mb-4 text-muted fs-5">
                        You are about to permanently delete student <strong>@Model.FirstName @Model.LastName</strong> (Roll No: <span class="font-monospace">@Model.RollNumber</span>) from the system.
                        This will remove their profile record entirely.
                    </p>

                    <div class="row justify-content-center mb-4">
                        <div class="col-md-8">
                            <ul class="list-group list-group-flush border text-start rounded">
                                <li class="list-group-item"><strong>Roll Number:</strong> @Model.RollNumber</li>
                                <li class="list-group-item"><strong>Full Name:</strong> @Model.FirstName @Model.LastName</li>
                                <li class="list-group-item"><strong>Email:</strong> @Model.Email</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Submission Form -->
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                Keep Student Profile
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash-alt me-1"></i> Yes, Delete Permanent Registry
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>