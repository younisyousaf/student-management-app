@page "/courses/new"
@page "/courses/{Id:int}/edit"
@inject ICourseService CourseService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<h3>@(Id.HasValue ? "Edit Course" : "Add Course")</h3>

<EditForm Model="@formModel" OnValidSubmit="HandleSubmit" FormName="CourseForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Code</label>
        <InputText class="form-control" @bind-Value="formModel.Code" disabled="@Id.HasValue" />
    </div>
    <div class="mb-3">
        <label>Name</label>
        <InputText class="form-control" @bind-Value="formModel.Name" />
    </div>
    <div class="mb-3">
        <label>Description</label>
        <InputTextArea class="form-control" @bind-Value="formModel.Description" />
    </div>
    <div class="mb-3">
        <label>Duration (months)</label>
        <InputNumber class="form-control" @bind-Value="formModel.DurationMonths" />
    </div>
    <div class="mb-3">
        <label>Fee Amount</label>
        <InputNumber class="form-control" @bind-Value="formModel.FeeAmount" />
    </div>

    @if (errorMessage != null)
    {
        <p class="text-danger">@errorMessage</p>
    }

    <button type="submit" class="btn btn-primary">Save</button>
</EditForm>

@code {
    [Parameter] public int? Id { get; set; }
    private CourseFormModel formModel = new();
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (Id.HasValue)
        {
            var course = CourseService.GetCourseById(Id.Value);
            if (course != null)
            {
                formModel = new CourseFormModel
                {
                    Code = course.Code,
                    Name = course.Name,
                    Description = course.Description,
                    DurationMonths = course.DurationMonths,
                    FeeAmount = course.FeeAmount
                };
            }
        }
    }

    private void HandleSubmit()
    {
        errorMessage = null;
        try
        {
            if (Id.HasValue)
            {
                CourseService.UpdateCourseDetails(Id.Value, formModel.Name, formModel.Description, formModel.DurationMonths);
                CourseService.UpdateCoursePricing(Id.Value, formModel.FeeAmount);
            }
            else
            {
                var course = new Course(formModel.Code, formModel.Name, formModel.DurationMonths, formModel.FeeAmount)
                {
                    Description = formModel.Description
                };
                CourseService.CreateCourse(course);
            }
            Navigation.NavigateTo("/courses");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    public class CourseFormModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int DurationMonths { get; set; } = 1;
        public decimal FeeAmount { get; set; }
    }
}