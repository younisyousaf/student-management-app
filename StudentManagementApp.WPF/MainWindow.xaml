<Window x:Class="StudentManagementApp.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Management System - Portal Dashboard" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation Menu -->
        <Border Background="#2C3E50" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="15,25">
                    <TextBlock Text="SMS Portal" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                    <!-- Navigation Sidebar Buttons -->
                    <Button x:Name="BtnShowStudents" Content="👥 Manage Students" Height="42" Margin="0,4" Click="BtnShowStudents_Click" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" FontSize="14"/>
                    <Button x:Name="BtnShowCourses" Content="📚 Manage Courses" Height="42" Margin="0,4" Click="BtnShowCourses_Click" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" FontSize="14"/>
                    <Button x:Name="BtnShowEnrollments" Content="🔗 Course Enrollments" Height="42" Margin="0,4" Click="BtnShowEnrollments_Click" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" FontSize="14"/>
                    <Button x:Name="BtnShowFees" Content="💰 Tuition &amp; Fees" Height="42" Margin="0,4" Click="BtnShowFees_Click" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" FontSize="14"/>
                    <Button x:Name="BtnShowAttendance" Content="📋 Attendance" Height="42" Margin="0,4" Click="BtnShowAttendance_Click" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" FontSize="14"/>
                </StackPanel>

                <!-- Dedicated Bottom Area for Sign Out Button -->
                <StackPanel Grid.Row="1" Margin="15,0,15,25">
                    <Separator Background="#34495E" Margin="0,0,0,15"/>
                    <Button x:Name="BtnLogout" Content="🚪 Sign Out" Height="40" Click="BtnLogout_Click" Background="#C0392B" Foreground="White" FontWeight="Bold" BorderThickness="0" FontSize="14">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace Area -->
        <Grid Grid.Column="1" Background="#F8F9FA">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Modern Top Bar Header Stack -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock x:Name="TxtViewHeader" Text="Welcome to Dashboard" FontSize="26" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock x:Name="TxtViewSubHeader" Text="Select an option from the sidebar menu to begin records administration." FontSize="13" Foreground="#7F8C8D" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- The Dynamic View Container -->
                <Grid Grid.Row="1">
                    <!-- Default Screen View (Shown initially) -->
                    <StackPanel x:Name="PanelWelcomeView" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🏫" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Global Administrative Hub" FontSize="20" FontWeight="Bold" Foreground="#34495E" HorizontalAlignment="Center"/>
                        <TextBlock Text="Please navigate using the sidebar tools to manage database layers." Foreground="#95A5A6" FontSize="14" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Core Dynamic View Host (Hidden initially) -->
                    <ContentControl x:Name="ActiveViewContainer" Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>