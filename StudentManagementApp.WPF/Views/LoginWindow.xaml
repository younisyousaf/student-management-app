<Window x:Class="StudentManagementApp.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Authentication" Height="550" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#F4F6F9">
    <Grid>
        <Border Margin="25" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center" Margin="30,20">
                <!-- Header Accent -->
                <TextBlock Text="🔒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Welcome Back" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                <TextBlock Text="Sign in to manage your student systems portal" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <!-- Inputs -->
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtUsername" Height="34" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtPassword" Height="34" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,25">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Status Label -->
                <TextBlock x:Name="LblError" Foreground="#E74C3C" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,15" HorizontalAlignment="Center" Visibility="Collapsed"/>

                <!-- Action Button -->
                <Button x:Name="BtnLogin" Content="Sign In Securely" Height="38" FontWeight="Bold" FontSize="14" Click="BtnLogin_Click" Background="#3498DB" Foreground="White" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Navigation link -->
                <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center" FontSize="13" Height="41">
                    <Run Text="New Administrator?" Foreground="#7F8C8D"/> 
                    <Hyperlink Click="LnkRegister_Click" Foreground="#3498DB" TextDecorations="None" FontWeight="SemiBold">Create an account</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>