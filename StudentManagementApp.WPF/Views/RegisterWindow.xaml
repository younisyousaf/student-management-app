<Window x:Class="StudentManagementApp.WPF.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Registration" Height="550" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#F4F6F9">
    <Grid>
        <Border Margin="20,20,20,20" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center" Margin="30,15,30,0" Height="489">
                <!-- Header Accent -->
                <TextBlock Text="👤" FontSize="36" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                <TextBlock Text="Register Admin" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                <TextBlock Text="Set up your global management system credentials" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <!-- Inputs -->
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtUsername" Height="34" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,12">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Email Address" FontSize="12" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtEmail" Height="34" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,12">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtPassword" Height="34" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,20">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Status Feedback Label -->
                <TextBlock x:Name="LblStatus" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,15" HorizontalAlignment="Center" Visibility="Collapsed"/>

                <!-- Submit Action Button -->
                <Button x:Name="BtnRegister" Content="Register Account" Height="38" FontWeight="Bold" FontSize="14" Click="BtnRegister_Click" Background="#2ECC71" Foreground="White" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Back to Login Navigation link -->
                <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center" FontSize="13">
                    <Hyperlink Click="LnkLogin_Click" Foreground="#7F8C8D" TextDecorations="None" FontWeight="SemiBold">Back to Sign In</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>