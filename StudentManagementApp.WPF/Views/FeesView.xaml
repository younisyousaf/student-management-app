<UserControl x:Class="StudentManagementApp.WPF.Views.FeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Column: Payment Intake Form Card -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" Margin="0,0,24,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Process Student Payment" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Record and audit institutional tuition remittances." FontSize="12" Foreground="#64748B" Margin="0,2,0,16" TextWrapping="Wrap"/>

                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Margin="0,0,0,16"/>

                <TextBlock Text="Select Student *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                <ComboBox x:Name="CboStudents" DisplayMemberPath="FullName" SelectedValuePath="Id" Margin="0,0,0,14" Padding="8">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <TextBlock Text="Select Course Context *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                <ComboBox x:Name="CboCourses" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,14" Padding="8">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <TextBlock Text="Amount Paid (PKR) *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtAmountPaid" Margin="0,0,0,14" Padding="8" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Remarks / Reference Ledger Tag" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtRemarks" Margin="0,0,0,20" Padding="8" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button Content="Save Fee Remittance" Click="BtnProcessPayment_Click" Padding="12" Background="#D97706" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock x:Name="LblStatus" Margin="0,12,0,0" TextWrapping="Wrap" FontWeight="Medium" Visibility="Collapsed" HorizontalAlignment="Center"/>
            </StackPanel>
                </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <DataGrid x:Name="DgFees" AutoGenerateColumns="False" IsReadOnly="True" 
                          Visibility="Visible" Background="Transparent" BorderThickness="0" RowHeight="46" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55"/>
                        <DataGridTextColumn Header="Student Profile" Binding="{Binding StudentName}" Width="*"/>
                        <DataGridTextColumn Header="Course Code" Binding="{Binding CourseCode}" Width="110"/>
                        <DataGridTextColumn Header="Amount Remitted" Binding="{Binding AmountPaid, StringFormat={}{0:N2} PKR}" Width="140"/>
                        <DataGridTextColumn Header="Payment Date" Binding="{Binding PaymentDate, StringFormat={}{0:MM/dd/yyyy}}" Width="120"/>
                        <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="PanelEmptyFees" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="Ledger balances clear. No payment receipts found." FontSize="15" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <TextBlock Text="Enter data inside the input workspace on the left to file records." FontSize="12" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>