<UserControl x:Class="StudentManagementApp.WPF.Views.CoursesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Academic Curriculum Management" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Maintain active training programs, adjust course pricing ledgers, and manage operational tracks." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Content="+ Add New Course" x:Name="BtnOpenCourseForm" Click="BtnOpenCourseForm_Click" 
                    HorizontalAlignment="Right" VerticalAlignment="Center" Padding="16,10" 
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <DataGrid x:Name="DgCourses" AutoGenerateColumns="False" IsReadOnly="True" 
                          Visibility="Visible" Background="Transparent" BorderThickness="0" RowHeight="44" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="110"/>
                        <DataGridTextColumn Header="Course Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding DurationMonths, StringFormat={}{0} Months}" Width="120"/>
                        <DataGridTextColumn Header="Base Fee" Binding="{Binding FeeAmount, StringFormat={}{0:N2} PKR}" Width="150"/>

                        <DataGridTemplateColumn Header="Actions" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="Edit" Click="BtnEditCourse_Click" Margin="0,0,8,0" Padding="10,4" Background="#F59E0B" Foreground="White" FontWeight="Medium" BorderThickness="0">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <Button Content="Delete" Click="BtnDeleteCourse_Click" Padding="10,4" Background="#EF4444" Foreground="White" FontWeight="Medium" BorderThickness="0">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="PanelEmptyCourses" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="No curriculum tracks active at this time." FontSize="15" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <TextBlock Text="Click the '+ Add New Course' button to get started." FontSize="12" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>