<Window x:Class="StudentManagementApp.WPF.Views.RecordPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Payment"
        Height="680"
        Width="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Border Margin="20"
            Background="White"
            CornerRadius="8"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Padding="20">

        <StackPanel>

            <TextBlock Text="Record Student Payment"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Record an additional payment against this student's fee ledger."
                       Margin="0,4,0,18"
                       Foreground="#64748B"
                       TextWrapping="Wrap"/>

            <Separator Margin="0,0,0,18"/>

            <TextBlock Text="Student"/>

            <TextBox x:Name="TxtStudentName"
                     Margin="0,5,0,12"
                     IsReadOnly="True"/>

            <TextBlock Text="Course"/>

            <TextBox x:Name="TxtCourseName"
                     Margin="0,5,0,12"
                     IsReadOnly="True"/>

            <TextBlock Text="Amount Due"/>

            <TextBox x:Name="TxtAmountDue"
                     Margin="0,5,0,12"
                     IsReadOnly="True"/>

            <TextBlock Text="Amount Paid So Far"/>

            <TextBox x:Name="TxtAmountPaidSoFar"
                     Margin="0,5,0,12"
                     IsReadOnly="True"/>

            <TextBlock Text="Remaining Balance"/>

            <TextBox x:Name="TxtRemainingBalance"
                     Margin="0,5,0,12"
                     IsReadOnly="True"/>

            <TextBlock Text="Payment Amount *"/>

            <TextBox x:Name="TxtAmountPaid"
                     Margin="0,5,0,12"/>

            <TextBlock Text="Remarks"/>

            <TextBox x:Name="TxtRemarks"
                     Height="70"
                     Margin="0,5,0,18"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right">

                <Button Content="Cancel"
            Width="90"
            Height="36"
            Margin="0,0,10,0"
            Click="BtnCancel_Click"
            Background="#64748B"
            Foreground="White"
            FontWeight="Medium"
            BorderThickness="0"
            Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Save Payment"
            Width="110"
            Height="36"
            Click="BtnSave_Click"
            Background="#D97706"
            Foreground="White"
            FontWeight="Medium"
            BorderThickness="0"
            Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>

            <TextBlock x:Name="LblStatus"
                       Margin="0,16,0,0"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

        </StackPanel>

    </Border>

</Window>