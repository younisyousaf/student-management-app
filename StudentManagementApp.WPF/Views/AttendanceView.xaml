<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="StudentManagementApp.WPF.Views.AttendanceView"
             Background="#F8FAFC" d:DesignHeight="700" d:DesignWidth="515">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" Margin="0,0,24,0">
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"  HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="Mark Attendance" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Record a student's attendance status for a course on a given date." FontSize="12" Foreground="#64748B" Margin="0,2,0,16" TextWrapping="Wrap"/>

                    <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Margin="0,0,0,16"/>

                    <TextBlock Text="Select Student *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CboStudents" DisplayMemberPath="FullName" SelectedValuePath="Id" Margin="0,0,0,16" Padding="8">
                        <ComboBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBlock Text="Select Course *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CboCourses" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,16" Padding="8">
                        <ComboBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBlock Text="Date *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <DatePicker x:Name="DpDate" Margin="0,0,0,16" Padding="8"/>

                    <TextBlock Text="Status *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CboStatus" Margin="0,0,0,16" Padding="8" SelectedIndex="0">
                        <ComboBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="Present"/>
                        <ComboBoxItem Content="Absent"/>
                        <ComboBoxItem Content="Late"/>
                        <ComboBoxItem Content="Excused"/>
                    </ComboBox>

                    <TextBlock Text="Remarks" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtRemarks" Margin="0,0,0,20" Padding="8" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>

                    <Button Content="⚡ Mark Attendance" Click="BtnMark_Click" Padding="12" Background="#2563EB" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <TextBlock x:Name="LblStatus" Margin="0,12,0,0" TextWrapping="Wrap" FontWeight="Medium" Visibility="Collapsed" HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <DataGrid x:Name="DgAttendance" AutoGenerateColumns="False" IsReadOnly="True"
                          Visibility="Visible" Background="Transparent" BorderThickness="0" RowHeight="46"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="120"/>
                        <DataGridTextColumn Header="Course" Binding="{Binding CourseName}" Width="120"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=\{0:MM/dd/yyyy\}}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="140"/>

                        <DataGridTemplateColumn Header="Actions" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="Edit" Click="BtnEditAttendance_Click" Padding="8,4" Background="#2563EB" Foreground="White" FontWeight="Medium" BorderThickness="0" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="PanelEmptyAttendance" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="No attendance records found in the database." FontSize="15" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <TextBlock Text="Select parameters on the left card to mark attendance." FontSize="12" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>