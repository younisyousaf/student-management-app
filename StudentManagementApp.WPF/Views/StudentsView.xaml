<UserControl x:Class="StudentManagementApp.WPF.Views.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header & Global Actions Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Student Directory Management" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Maintain global student profiles, access active enrollments, and coordinate registration metrics." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Content="+ Register New Student" x:Name="BtnOpenRegisterForm" Click="BtnOpenRegisterForm_Click" 
                    HorizontalAlignment="Right" VerticalAlignment="Center" Padding="16,10" 
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Main Display Directory DataGrid Card -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <DataGrid x:Name="DgStudents" AutoGenerateColumns="False" IsReadOnly="True" 
                          Visibility="Visible" Background="Transparent" BorderThickness="0" RowHeight="44" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Roll No" Binding="{Binding RollNumber}" Width="120"/>
                        <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*"/>
                        <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="*"/>
                        <DataGridTextColumn Header="Email Address" Binding="{Binding Email}" Width="1.5*"/>

                        <!-- Modern CRUD Action Column Block -->
                        <DataGridTemplateColumn Header="Actions" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="Edit" Click="BtnEditStudent_Click" Margin="0,0,8,0" Padding="10,4" Background="#F59E0B" Foreground="White" FontWeight="Medium" BorderThickness="0" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <Button Content="Delete" Click="BtnDeleteStudent_Click" Padding="10,4" Background="#EF4444" Foreground="White" FontWeight="Medium" BorderThickness="0" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Fallback Empty Placeholder UI -->
                <StackPanel x:Name="PanelEmptyStudents" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="No student profiles registered in system yet." FontSize="15" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <TextBlock Text="Click the '+ Register New Student' button to get started." FontSize="12" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>