<Window x:Class="StudentManagementApp.WPF.Views.CourseFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Course Setup Workspace" Height="530" Width="440" 
        WindowStartupLocation="CenterOwner" Background="#FFFFFF" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtHeaderTitle" Text="Create New Course" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock x:Name="TxtHeaderSubtitle" Text="Ensure required structural variables are uniquely set." FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Margin="0,15,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Course Code *" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                <TextBox x:Name="TxtCourseCode" Margin="0,6,0,16" Padding="8" BorderBrush="#CBD5E1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Course Name *" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                <TextBox x:Name="TxtCourseName" Margin="0,6,0,16" Padding="8" BorderBrush="#CBD5E1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Description" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                <TextBox x:Name="TxtDescription" Margin="0,6,0,16" Padding="8" Height="65" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderBrush="#CBD5E1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Duration (Months) *" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox x:Name="TxtDuration" Margin="0,6,0,0" Padding="8" BorderBrush="#CBD5E1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Tuition Fee (PKR) *" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox x:Name="TxtFee" Margin="0,6,0,0" Padding="8" BorderBrush="#CBD5E1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock x:Name="LblStatus" Margin="0,0,0,12" TextWrapping="Wrap" FontWeight="Medium" Visibility="Collapsed"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Cancel" x:Name="BtnCancel" Click="BtnCancel_Click" Grid.Column="0" Margin="0,0,8,0" Padding="12" Background="#E2E8F0" Foreground="#475569" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Save Course" x:Name="BtnSaveCourse" Click="BtnSaveCourse_Click" Grid.Column="1" Margin="8,0,0,0" Padding="12" Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Window>